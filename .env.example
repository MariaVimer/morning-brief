# === REQUIRED ===

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Atlassian (Jira + Confluence)
JIRA_EMAIL=maria.vimer@uipath.com
JIRA_TOKEN=...                         # https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_OKR_PAGE_ID=90404585567    # from the URL: /wiki/spaces/.../pages/{ID}/...

# Slack (existing bot)
SLACK_BOT_TOKEN=xoxb-...
SLACK_USER_ID=...                      # Your Slack user ID (right-click your name → Copy member ID)

# Google Calendar
GOOGLE_CREDENTIALS_JSON=...            # path to credentials.json from Google Cloud Console
GOOGLE_TOKEN_JSON=...                  # path to token.json (auto-generated after first auth)

# Microsoft (Outlook / Exchange)
MS_CLIENT_ID=...                       # Azure AD app registration
MS_CLIENT_SECRET=...
MS_TENANT_ID=...
MS_USER_EMAIL=maria.vimer@uipath.com

# Snowflake
SNOWFLAKE_ACCOUNT=uipath-uipath_observability
SNOWFLAKE_USER=maria.vimer@uipath.com
SNOWFLAKE_PASSWORD=...                 # your UiPath SSO password, or use SNOWFLAKE_AUTHENTICATOR=externalbrowser
SNOWFLAKE_WAREHOUSE=COMPUTE_WH        # check your Snowflake settings
SNOWFLAKE_DATABASE=UIPATH_OBSERVABILITY
SNOWFLAKE_SCHEMA=PUBLIC               # adjust to your schema

# Salesforce (via MCP or direct)
SALESFORCE_INSTANCE_URL=https://uipath.my.salesforce.com
SALESFORCE_ORG_ALIAS=uipath
# For direct API access (alternative to MCP):
# SALESFORCE_CLIENT_ID=...
# SALESFORCE_CLIENT_SECRET=...
# SALESFORCE_USERNAME=maria.vimer@uipath.com
# SALESFORCE_PASSWORD=...
# SALESFORCE_SECURITY_TOKEN=...

# === OPTIONAL ===
BRIEF_TIMEZONE=America/New_York
LOOKBACK_HOURS=16                      # how far back to look for Slack messages (default: since yesterday 5pm)
